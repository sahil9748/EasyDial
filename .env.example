# Environment Configuration
NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=callcenter
DB_USER=callcenter
DB_PASS=changeme_db_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=24h

# Asterisk ARI
ARI_URL=http://localhost:8088
ARI_USER=callcenter
ARI_PASS=changeme_ari_password
ARI_APP=callcenter

# Asterisk AMI
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=callcenter
AMI_PASS=changeme_ami_password

# Domain (for WSS/HTTPS)
DOMAIN=your-domain.com

# Recordings
RECORDING_PATH=/var/spool/asterisk/monitor

# Encryption key for trunk passwords (32 hex chars)
TRUNK_ENCRYPT_KEY=0123456789abcdef0123456789abcdef
